# Groq keys usually start with gsk_. xAI keys should be used with XAI_API_KEY.
GROQ_API_KEY=gsk-your-groq-key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional xAI/Grok.com provider instead of Groq.
XAI_API_KEY=
XAI_MODEL=grok-4.3

# Preferred no-Google-key method. Ask the client to deploy google-apps-script/Code.gs
# in their Sheet and paste the Web App URL here.
GOOGLE_APPS_SCRIPT_WEBAPP_URL=
GOOGLE_APPS_SCRIPT_TOKEN=

# Optional fallback: service account method.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY_ID=

GOOGLE_SHEET_ID=1UdG5POoK8-8yTmLArbyzAg1qMlF7N7f0zwLpR77Nkhc
GOOGLE_SHEET_NAME=Sheet1
PORT=3000
